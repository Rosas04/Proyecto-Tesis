# URL de tu proyecto en Supabase (Project Settings > API)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública (anon/publishable) de Supabase (Project Settings > API)
VITE_SUPABASE_ANON_KEY=tu_clave_publica_aqui

# URL del backend de FrontMind AI (FastAPI)
# En desarrollo local:
VITE_API_URL=http://127.0.0.1:8000
# En producción, usar la URL pública del backend desplegado, ejemplo:
# VITE_API_URL=https://frontmind-backend.onrender.com